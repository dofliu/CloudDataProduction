# 複製成 .env 後填入實際值。.env 不入庫(見 .gitignore)。

# ── 場景 ──────────────────────────────────────────────
# 啟動時載入的場景檔(相對 repo 根目錄)
SCENARIO_FILE=scenarios/p0_single_cnc.yaml

# ── API(FastAPI / uvicorn)────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# 設備目錄(/api/catalog)公布給學生連 Modbus 的位址(LAN IP / Tailscale 位址)
PUBLIC_HOST=127.0.0.1
# 教師面 API 需帶此 token(P0 尚未強制,P2 起生效)
TEACHER_TOKEN=change-me-teacher-token

# ── Modbus 轉接層 ─────────────────────────────────────
# 場景 YAML 也可指定;此處可覆寫。Windows 綁 502 需系統管理員,
# 開發時建議改 5020 之類的高位埠避免權限問題。
MODBUS_PORT=502
MODBUS_HOST=0.0.0.0

# ── OPC-UA / MQTT 轉接層(P1)──────────────────────────
# MQTT 走內嵌純 Python broker(amqtt),不需 Docker / mosquitto。設 false 可關閉。
OPCUA_ENABLED=true
OPCUA_PORT=4840
MQTT_ENABLED=true
MQTT_PORT=1883

# ── Historian(TimescaleDB)────────────────────────────
# 連不上時引擎仍可運行,Historian 自動降級為 in-memory(僅供 P0 驗證)。
TIMESCALE_DSN=postgresql://postgres:postgres@localhost:5432/clouddata
HISTORIAN_ENABLED=true
