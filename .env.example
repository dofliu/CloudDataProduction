# 複製成 .env 後填入實際值。.env 不入庫(見 .gitignore)。

# ── 場景 ──────────────────────────────────────────────
# 啟動時載入的場景檔(相對 repo 根目錄)
SCENARIO_FILE=scenarios/p0_single_cnc.yaml

# ── API(FastAPI / uvicorn)────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# 設備目錄(/api/catalog)公布給學生連 Modbus 的位址(LAN IP / Tailscale 位址)
PUBLIC_HOST=127.0.0.1
# 教師面 API 需帶此 token(P0 尚未強制,P2 起生效)
TEACHER_TOKEN=change-me-teacher-token

# ── 工業協定埠(統一在 6xxx 區,避開 Windows 保留/服務埠)──
# 場景 YAML 也可指定;此處覆寫。Windows 綁 502 需系統管理員,故用高位埠。
MODBUS_PORT=6020
MODBUS_HOST=0.0.0.0

# ── OPC-UA / MQTT 轉接層(P1)──────────────────────────
# MQTT 走內嵌純 Python broker(amqtt),不需 Docker / mosquitto。設 false 可關閉。
OPCUA_ENABLED=true
OPCUA_PORT=6041
MQTT_ENABLED=true
MQTT_PORT=6083

# ── multi_port 疊加層(進階)──────────────────────────
# 除了共用埠,再為每台設備各起一個專屬 Modbus 埠(從 base 起遞增),
# 讓每台設備像真實設備一樣有自己的 IP:port。與 channel_mux 並存。
MULTI_PORT_ENABLED=true
MULTI_PORT_MODBUS_BASE=6100

# ── 教師控制埠(可寫線圈)─────────────────────────────
# 設了埠號才啟用:該埠的 FC05 寫線圈(run_enable / reset_fault)會轉成引擎命令。
# 學生埠(MODBUS_PORT)的線圈仍 FC01 唯讀。此埠只給教師(走 Tailscale / 不對學生公布)。
MODBUS_CONTROL_PORT=6023

# ── Historian(本機持久化)────────────────────────────
# DB_BACKEND:sqlite(本機檔案,免 Docker,進程重啟資料不失)| timescale(production)| memory
# historian.db = 高頻 telemetry 時序(學生分析用)
DB_BACKEND=sqlite
SQLITE_PATH=historian.db
HISTORIAN_ENABLED=true
TIMESCALE_DSN=postgresql://postgres:postgres@localhost:5432/clouddata

# ── 營運狀態持久化(工單 / 學生預測 / OEE 累積器)──────
# state.db = 低頻營運狀態;進程重啟工單/預測/OEE 不歸零。設 false 走純記憶體。
STATE_ENABLED=true
STATE_PATH=state.db

# ── MCP server(老師本機 Claude Desktop,P2)────────────
# mcp/server.py 啟動時讀:打哪台世界伺服器、帶哪個 teacher token。
WORLD_API_URL=http://127.0.0.1:8077
# (TEACHER_TOKEN 共用上方那個)

# ── 自然語言建廠(選用 LLM)─────────────────────────────
# 預設規則式解析,免 key。要改用 Gemini 再填:
# GEMINI_API_KEY=
